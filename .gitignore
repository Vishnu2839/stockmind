# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
.venv/
venv/
env/
ENV/

# ─── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ─── Machine Learning Models ──────────────────────────────────
backend/models/*.h5
backend/models/*.pkl
backend/models/*.pt
backend/models/*.pth
