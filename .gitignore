!backend/models/stockmind_*_model.h5

# ─── Node / Frontend ──────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDEs & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── OS ───────────────────────────────────────────────────────
